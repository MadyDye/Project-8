#ifndef DATE_H
#define DATE_H

#include <iostream>
using namespace std;

class Date {
private:
    int month, day, year;

public:
    Date(int m=1, int d=1, int y=2000);

    void setDate(int m, int d, int y);
    int getMonth() const;
    int getDay() const;
    int getYear() const;

    bool operator==(const Date& other) const;

    friend istream& operator>>(istream& in, Date& d);
    friend ostream& operator<<(ostream& out, const Date& d);
};

#endif
